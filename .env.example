# ── MensajesCortos – Variables de entorno ──
# Copia este archivo como .env.local y ajusta los valores.

# Base de datos (Vercel PostgreSQL recomendado, o cualquier DB soportada por Prisma)
# Para desarrollo local con SQLite:
DATABASE_URL="file:./db/custom.db"

# Para Vercel con PostgreSQL (ejemplo):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Nota sobre la IA ──
# La API Key de Gemini se ingresa desde la interfaz de usuario (campo en la pestaña Campaña).
# No es necesario ponerla aquí, pero puedes definir un valor por defecto si lo deseas:
# NEXT_PUBLIC_DEFAULT_GEMINI_API_KEY=""