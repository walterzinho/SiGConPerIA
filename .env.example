# ── SiGConPerIA – Variables de entorno ──

# ═══ DESARROLLO LOCAL (SQLite) ═══
DATABASE_URL="file:db/custom.db"

# ═══ PRODUCCIÓN CON TURSO (Vercel) ═══
# Para que los datos persistan en Vercel, necesitas Turso (SQLite en la nube, gratis).
#
# PASOS:
# 1. Crea una cuenta gratuita en https://turso.tech
# 2. Crea una base de datos nueva (ej: "sigconperia")
# 3. En Settings de la base de datos, copia la URL y crea un Auth Token
# 4. En Vercel → tu proyecto → Settings → Environment Variables, agrega:
#
#    DATABASE_URL = libsql://sigconperia-tu-usuario.turso.io
#    DATABASE_AUTH_TOKEN = tu-token-de-autenticacion
#
# Las tablas se crean automáticamente en Turso la primera vez que la app se conecta.
# NO necesitas ejecutar prisma db push para Turso.